{
  "name": "@iot/iot-monolith",
  "version": "8.8.3",
  "description": "monolithic approach to Node.js-enabled home automation",
  "repository": {
    "type": "git",
    "url": "https://git.i.wurstsalat.cloud/iot/iot-monolith.git"
  },
  "license": "UNLICENSED",
  "author": "Lennart Pelz <mail@mrpelz.de>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./tree": {
      "types": "./dist/lib/tree/main.d.ts",
      "default": "./dist/lib/tree/main.js"
    },
    "./tree-introspection": {
      "types": "./dist/lib/tree/operations/introspection.d.ts",
      "default": "./dist/lib/tree/operations/introspection.js"
    },
    "./tree-parents": {
      "types": "./dist/lib/tree/operations/parents.d.ts",
      "default": "./dist/lib/tree/operations/parents.js"
    },
    "./tree-paths": {
      "types": "./dist/lib/tree/operations/paths.d.ts",
      "default": "./dist/lib/tree/operations/paths.js"
    },
    "./tree-serialization": {
      "types": "./dist/lib/tree/operations/serialization.d.ts",
      "default": "./dist/lib/tree/operations/serialization.js"
    }
  },
  "main": "dist/main.js",
  "module": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist/**/*.{js,map,ts}",
    "Dockerfile",
    "npm-shrinkwrap.json"
  ],
  "dependencies": {
    "@mrpelz/misc-utils": "6.1.0",
    "@mrpelz/modifiable-date": "6.1.0",
    "@mrpelz/observable": "6.1.0",
    "@mrpelz/struct": "6.1.0",
    "pjlink-control": "1.1.0",
    "prom-client": "15.1.3",
    "proper-tags": "2.0.2",
    "suncalc": "2.0.0",
    "uuid": "14.0.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@mrpelz/boilerplate-common": "16.2.0",
    "@mrpelz/boilerplate-node": "16.2.0",
    "@types/suncalc": "1.9.2",
    "@types/ws": "8.18.1",
    "undici": "8.7.0"
  },
  "packageManager": "npm@11.14.1+sha512.6a8a4d67478497a2dbc6815cad72e64c43f33413717e242756047d466241ab39bee61e691683a64658e94496ec5f1a1c05e4a5ec62dcc773280dfd949443a367",
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn"
    }
  }
}
